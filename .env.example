# Elaph Content Pipeline Configuration
# Copy this file to .env and fill in your values

# Supabase Configuration
SUPABASE_URL=your-supabase-url-here
SUPABASE_KEY=your-supabase-key-here

# Google Cloud Platform
GCP_PROJECT_ID=your-project-id
BIGQUERY_DATASET=your-bigquery-dataset
BIGQUERY_TABLE=your-bigquery-table
GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Sitemap URLs
SITEMAP_MAIN=https://example.com/sitemap.xml
SITEMAP_GOOGLE_NEWS=https://example.com/news-sitemap.xml

# Crawler Settings
BATCH_SIZE=5
REQUEST_DELAY=1.0
MAX_RETRIES=3
MAX_URL_FAILURES=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/crawler.log